CLIENT=analytics
DIR=security/clients/$CLIENT

openssl req -newkey rsa:2048 -nodes \
  -keyout $DIR/client.key \
  -out    $DIR/client.csr \
  -subj "/CN=$CLIENT"

openssl x509 -req \
  -in  $DIR/client.csr \
  -CA  security/ca/ca.crt \
  -CAkey security/ca/ca.key \
  -CAcreateserial \
  -out $DIR/client.crt \
  -days 3650
